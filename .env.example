# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/mudric_portfolio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mudric_portfolio
REDIS_URL=redis://redis:6379/0

# Data Providers (all optional — app works without these)
FRED_API_KEY=                    # free at fred.stlouisfed.org
ALPHA_VANTAGE_KEY=               # free tier: 25 calls/day
POLYGON_API_KEY=                 # free tier available
FMP_API_KEY=                     # free tier: 250 calls/day
TIINGO_API_KEY=                  # free tier available

# App Config
APP_NAME=Mudric Lab Portfolio Intelligence
DEFAULT_CURRENCY=USD
DEFAULT_BENCHMARK=SPY
CACHE_TTL_PRICES=3600            # 1 hour
CACHE_TTL_FUNDAMENTALS=86400     # 24 hours
CACHE_TTL_ETF_PROFILE=604800     # 1 week

# Superset
SUPERSET_SECRET_KEY=gen_a_secret_key_here
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin

# Email (optional, for scheduled reports)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
